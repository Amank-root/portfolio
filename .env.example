# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-06-04

# Sanity Tokens
SANITY_API_READ_TOKEN=your_read_token
SANITY_API_WRITE_TOKEN=your_write_token_with_editor_permissions
SANITY_REVALIDATE_SECRET=your_random_secret_string

# Blog external ingest API key
BLOG_INGEST_API_KEY=your_random_api_key_for_external_blog_posting

# Dashboard access key (only you know this)
DASHBOARD_SECRET_KEY=your_super_secret_dashboard_key

NEXT_PUBLIC_FORM=your_formspree_form_id
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Formspree (optional, for contact form)
# FORMSPREE_ENDPOINT=https://formspree.io/f/your_id
